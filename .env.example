# ===== 네이버 검색 API (developers.naver.com) =====
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ===== 캐시 =====
# 캐시 유지 시간(초). 기본 600(10분)
CACHE_TTL_SECONDS=600
# Upstash Redis (선택). 미설정 시 서버 인메모리 캐시로 자동 폴백
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== 이메일 발송 (선택) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
# Gmail은 '앱 비밀번호'를 사용하세요 (일반 비밀번호 아님)
SMTP_PASS=
# 기본 수신자 (요청에 recipient가 없을 때 사용)
MAIL_RECIPIENT=
